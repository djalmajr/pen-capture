{
  "manifest_version": 3,
  "name": "Pen Capture",
  "version": "0.1.6",
  "description": "Copy rendered web elements as editable layers for Pen",
  "permissions": ["activeTab", "clipboardWrite", "offscreen", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Capture an element for Pen",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": { "service_worker": "background.js", "type": "module" },
  "web_accessible_resources": [{
    "resources": ["icons/pen-mark.png"],
    "matches": ["<all_urls>"]
  }]
}
