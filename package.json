{
  "name": "@djalmajr/pen-capture",
  "version": "0.1.6",
  "description": "Capture rendered web UI as editable Pen.dev layers.",
  "type": "module",
  "bin": { "pen-capture": "./bin/pen-capture.mjs" },
  "files": [
    "bin/pen-capture.mjs",
    "src/build-batch.mjs",
    "src/capture-element.mjs",
    "src/capture-url.mjs",
    "src/convert-capture.mjs",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/djalmajr/pen-capture.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "build": "bun scripts/build-extension.mjs",
    "capture:source": "bun scripts/capture-source-screenshot.mjs",
    "compare:visual": "bun scripts/compare-visual.mjs",
    "smoke:clipboard": "bun scripts/smoke-clipboard.mjs",
    "smoke:picker": "bun scripts/smoke-picker.mjs",
    "smoke:iframe": "bun scripts/smoke-iframe-picker.mjs",
    "smoke:extension-iframe": "bun scripts/smoke-extension-iframe.mjs",
    "smoke:preview-01": "bun scripts/smoke-preview01-fidelity.mjs",
    "smoke:preview-02": "bun scripts/smoke-preview02-fidelity.mjs",
    "test": "bun test",
    "verify": "bun test && bun scripts/build-extension.mjs"
  },
  "dependencies": {
    "playwright": "1.61.1"
  }
}
